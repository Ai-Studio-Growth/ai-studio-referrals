# ─────────────────────────────────────────────────────────────────────────────
# ReferLift environment configuration
# Copy to `.env` (`cp .env.example .env`). Every integration is configured here —
# no secrets are ever hard-coded. Unset adapters fall back to safe console stubs.
# ─────────────────────────────────────────────────────────────────────────────

# Core ------------------------------------------------------------------------
# PostgreSQL (e.g. Neon). DATABASE_URL = pooled connection used by the app;
# DIRECT_URL = direct connection used for migrations / db push.
# Neon examples (note ?sslmode=require):
#   DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
#   DIRECT_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/aistudio?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/aistudio?schema=public"
# Public base URL used to build short links / QR codes.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret used to sign inbound webhook payloads & API keys.
APP_SECRET="dev-secret-change-me"

# Auth adapters ---------------------------------------------------------------
AUTH_PROVIDER="credentials"        # credentials | magic-link | google | apple | github | saml
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
SAML_METADATA_URL=""

# Payout adapters -------------------------------------------------------------
PAYOUT_PROVIDER="console"          # console | stripe | paypal | razorpay | wise | tremendous
STRIPE_SECRET_KEY=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
WISE_API_TOKEN=""
TREMENDOUS_API_KEY=""

# Messaging adapters ----------------------------------------------------------
EMAIL_PROVIDER="console"           # console | resend | sendgrid
RESEND_API_KEY=""
SENDGRID_API_KEY=""
EMAIL_FROM="rewards@referlift.dev"
SMS_PROVIDER="console"             # console | twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
SLACK_WEBHOOK_URL=""               # admin alerts
DISCORD_WEBHOOK_URL=""

# E-commerce ------------------------------------------------------------------
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
WOOCOMMERCE_CONSUMER_KEY=""
WOOCOMMERCE_CONSUMER_SECRET=""
STRIPE_BILLING_WEBHOOK_SECRET=""

# CRM & analytics -------------------------------------------------------------
HUBSPOT_API_KEY=""
SALESFORCE_CLIENT_ID=""
SEGMENT_WRITE_KEY=""
NEXT_PUBLIC_GA4_ID=""
MIXPANEL_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""

# Automation ------------------------------------------------------------------
ZAPIER_WEBHOOK_URL=""
OUTBOUND_WEBHOOK_URL=""             # default outbound webhook for conversion/payout events
