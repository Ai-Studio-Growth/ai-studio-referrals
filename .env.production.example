# ── Production env (Hostinger Node.js app) ───────────────────────────────────
# Set these in the server's .env (or hPanel → Node.js App → Environment vars).
# Never commit real values.

# Neon Postgres — pooled URL for the app, direct URL for migrations/db push.
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Public URL of the deployed app (your domain).
NEXT_PUBLIC_APP_URL="https://referrals.yourdomain.com"

# Strong random secret (used to sign sessions, hash IPs, verify webhooks).
# Generate: openssl rand -hex 32
APP_SECRET="change-me-to-a-64-char-random-hex"

NODE_ENV="production"

# Integrations (optional — unset adapters fall back to console stubs).
PAYOUT_PROVIDER="console"
EMAIL_PROVIDER="console"
SMS_PROVIDER="console"
EMAIL_FROM="rewards@yourdomain.com"
# STRIPE_SECRET_KEY=""
# RESEND_API_KEY=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# SLACK_WEBHOOK_URL=""
