// ReferLift — universal multi-tenant referral engine
// Local dev uses SQLite for zero-config setup. For production, switch the
// provider to "postgresql" and point DATABASE_URL at Postgres — the schema is
// written to be portable (enums are modeled as strings + app-level validation
// so the same schema runs on either engine).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Tenancy & access ────────────────────────────────────────────────────────

model Org {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // White-label branding (overrides design tokens at runtime)
  logoUrl       String?
  brandColor    String  @default("256 88% 60%") // HSL triplet
  accentColor   String  @default("192 92% 50%")
  customDomain  String? @unique
  createdAt DateTime @default(now())

  currency  String   @default("USD") // ISO 4217 — drives money formatting in the workspace

  // ── Subscription / billing (managed from the platform admin) ──
  plan        String    @default("free")     // free | starter | growth | scale
  subStatus   String    @default("trialing") // trialing | active | past_due | canceled
  mrrCents    Int       @default(0)          // monthly recurring revenue
  seats       Int       @default(3)
  trialEndsAt DateTime?
  renewsAt    DateTime?

  members      Membership[]
  campaigns    Campaign[]
  users        EndUser[]
  referrals    Referral[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  accounts     Account[]
  integrations Integration[]
  notifications Notification[]
}

// ─── Authentication ──────────────────────────────────────────────────────────

// A login identity. Three roles share this table:
//   super_admin — the platform operator (no org)
//   advertiser  — owns/administers a workspace (campaign advertiser)
//   referrer    — an end user who refers; linked to an EndUser profile
// Passwords are stored only as scrypt hashes; sessions store only a token hash.
model Account {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("advertiser") // super_admin | advertiser | referrer
  status       String    @default("active")     // active | suspended
  orgId        String?
  org          Org?      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  endUserId    String?   @unique
  endUser      EndUser?  @relation(fields: [endUserId], references: [id], onDelete: SetNull)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  sessions  Session[]
  receipts  NotificationReceipt[]

  @@index([orgId])
}

// An authenticated session. The cookie holds a random token; we persist only
// sha256(token) so a database leak cannot be replayed as a valid session.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipHash    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([accountId])
}

// A person who administers an org (admin/manager/viewer).
model Membership {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email     String
  name      String
  role      String   @default("admin") // admin | manager | viewer
  createdAt DateTime @default(now())

  @@unique([orgId, email])
  @@index([orgId])
}

model ApiKey {
  id         String   @id @default(cuid())
  orgId      String
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name       String
  prefix     String   @unique // shown in UI, e.g. rl_live_ab12
  hashedKey  String   // sha256(secret) — full key only shown once on creation
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([orgId])
}

// ─── Campaigns (config-driven, no code changes to launch) ────────────────────

model Campaign {
  id          String   @id @default(cuid())
  orgId       String
  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  status      String   @default("active") // draft | active | paused | ended
  startAt     DateTime @default(now())
  endAt       DateTime?

  // ── Trigger: which event counts as a conversion ──
  // signup | first_purchase | subscription | kyc_complete | custom_event
  triggerEvent      String  @default("signup")
  triggerCustomName String? // when triggerEvent = custom_event

  // ── Attribution ──
  attributionModel  String @default("last_touch") // first_touch | last_touch
  attributionWindowDays Int @default(30)

  // ── Reward config (JSON blobs validated by zod at the app layer) ──
  // See lib/config/campaign-config.ts for the shape. Supports cash / credit /
  // discount(% or flat) / free_months / points / gift / tiered, one-time or
  // recurring, and double-sided (referrer + referee).
  referrerReward Json
  refereeReward  Json?

  // ── Caps & eligibility ──
  rewardHoldDays      Int     @default(7)   // payout hold period before release
  maxRewardsPerUser   Int?                  // null = unlimited
  totalBudgetCents    Int?                  // null = unlimited
  eligibility         Json?                 // { newUsersOnly, allowedCountries, minOrderCents, ... }

  // ── A/B testing ──
  abTestKey   String?  // campaigns sharing a key are variants
  abWeight    Int      @default(100) // traffic split weight

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrals   Referral[]
  conversions Conversion[]
  rewards     Reward[]

  @@unique([orgId, slug])
  @@index([orgId, status])
}

// ─── End users (the people who refer / are referred) ─────────────────────────

model EndUser {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  avatarUrl String?
  phone     String?
  country   String?
  createdAt DateTime @default(now())

  referralsMade Referral[]   @relation("Referrer")
  conversions   Conversion[] @relation("RefereeUser")
  rewards       Reward[]
  payouts       Payout[]
  walletCents   Int          @default(0) // available balance
  account       Account?     // optional login for the referrer portal

  @@unique([orgId, email])
  @@index([orgId])
}

// ─── Integrations & notifications (managed from the platform admin) ───────────

model Integration {
  id          String    @id @default(cuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  provider    String    // stripe | paypal | resend | twilio | slack | shopify | hubspot | segment | posthog
  category    String    // payouts | messaging | ecommerce | crm | analytics
  status      String    @default("disconnected") // connected | disconnected | error
  config      Json?
  connectedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([orgId, provider])
  @@index([orgId])
}

model Notification {
  id        String   @id @default(cuid())
  orgId     String?  // null = platform-wide broadcast
  org       Org?     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  audience  String   @default("all")   // all | advertisers | referrers
  channel   String   @default("inapp") // inapp | email
  title     String
  body      String
  status    String   @default("sent")  // draft | sent
  createdAt DateTime @default(now())

  receipts  NotificationReceipt[]

  @@index([orgId])
  @@index([createdAt])
}

model NotificationReceipt {
  id             String       @id @default(cuid())
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@unique([accountId, notificationId])
  @@index([accountId])
}

// ─── No-code platform extensibility ──────────────────────────────────────────

// The integration catalog the super admin can extend from the UI — add a new
// provider (name, category, config fields) with NO code change; clients then
// connect against it via the Integration model.
model IntegrationProvider {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String   // payouts | messaging | ecommerce | crm | analytics | other
  description String?
  // JSON array of { key, label, type } describing the config form fields.
  fields      Json?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Arbitrary platform configuration the super admin edits from the UI
// (feature flags, limits, branding, defaults) — no redeploy required.
model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // stored as text; booleans/numbers parsed by the reader
  group     String   @default("general")
  label     String?
  type      String   @default("text") // text | number | boolean
  updatedAt DateTime @updatedAt
}

// A lightweight in-product community feed (announcements + member posts).
model CommunityPost {
  id         String   @id @default(cuid())
  authorName String
  authorRole String   @default("member") // team | advertiser | referrer | member
  category   String   @default("general") // general | announcements | feature-requests | wins
  title      String
  body       String
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ─── Referral codes / links ──────────────────────────────────────────────────

model Referral {
  id         String   @id @default(cuid())
  orgId      String
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  referrerId String
  referrer   EndUser  @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)

  code      String   @unique // short, URL-safe, e.g. ALEX-7Q2K
  createdAt DateTime @default(now())

  clicks      Click[]
  conversions Conversion[]

  @@unique([campaignId, referrerId]) // one code per user per campaign
  @@index([orgId])
  @@index([code])
}

model Click {
  id         String   @id @default(cuid())
  referralId String
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  ipHash     String?  // hashed, never store raw IP
  deviceHash String?  // fingerprint hash for duplicate-device detection
  country    String?
  userAgent  String?
  referer    String?
  createdAt  DateTime @default(now())

  @@index([referralId])
  @@index([createdAt])
}

// ─── Conversions (a trigger event fired & was attributed) ────────────────────

model Conversion {
  id         String   @id @default(cuid())
  orgId      String
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  referralId String
  referral   Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)
  refereeUserId String?
  refereeUser   EndUser? @relation("RefereeUser", fields: [refereeUserId], references: [id])

  event        String   // the trigger event name that fired
  valueCents   Int      @default(0) // order value etc., drives % rewards
  status       String   @default("pending") // pending | approved | rejected
  attribution  String   @default("last_touch")
  idempotencyKey String? @unique // dedupes repeated webhook deliveries
  createdAt    DateTime @default(now())

  rewards Reward[]

  @@index([orgId])
  @@index([campaignId, status])
  @@index([referralId])
}

// ─── Rewards & payouts ───────────────────────────────────────────────────────

model Reward {
  id           String   @id @default(cuid())
  orgId        String
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  conversionId String?
  conversion   Conversion? @relation(fields: [conversionId], references: [id])
  userId       String
  user         EndUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  side       String   // referrer | referee
  type       String   // cash | credit | discount | free_months | points | gift
  amountCents Int     @default(0)
  unit       String?  // for points/free_months/discount → "points" | "months" | "percent"
  quantity   Int      @default(0)
  // pending → on hold; approved → cleared; paid → paid out; rejected
  status     String   @default("pending")
  holdUntil  DateTime?
  payoutId   String?
  payout     Payout?  @relation(fields: [payoutId], references: [id])
  createdAt  DateTime @default(now())

  @@index([orgId])
  @@index([userId, status])
  @@index([campaignId])
}

model Payout {
  id         String   @id @default(cuid())
  orgId      String
  userId     String
  user       EndUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents Int
  method     String   // stripe | paypal | razorpay | wise | tremendous | console
  status     String   @default("requested") // requested | processing | paid | failed
  reference  String?  // external provider reference id
  createdAt  DateTime @default(now())
  paidAt     DateTime?

  rewards Reward[]

  @@index([orgId])
  @@index([userId, status])
}

// ─── Fraud & audit ───────────────────────────────────────────────────────────

model FraudFlag {
  id         String   @id @default(cuid())
  orgId      String
  // What was flagged
  subjectType String  // referral | conversion | user
  subjectId   String
  reason      String  // self_referral | ip_velocity | device_duplicate | disposable_email | ...
  severity    String  @default("medium") // low | medium | high
  status      String  @default("open")   // open | cleared | confirmed
  details     Json?
  createdAt   DateTime @default(now())

  @@index([orgId, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor     String   // system | admin email | api key prefix
  action    String   // referral.created | click.tracked | conversion.recorded | reward.issued | payout.requested | ...
  entity    String?  // entity id touched
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([action])
}
